# Copy to .agent_teams/.env and fill values

# Optional: override default paths
# AGENT_TEAMS_DB_PATH=agent_teams.db
# AGENT_TEAMS_ROLES_DIR=roles
OPENAI_API_KEY=<your-openai-api-key>
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Optional: disable TLS certificate verification for LLM HTTP requests
# AGENT_TEAMS_LLM_SSL_VERIFY=false
