# Agent-teams runtime base image.
# Contains a self-contained uv toolchain under /opt/agent-runtime/ that can be
# mounted into any x86_64 Linux container via --volumes-from.
#
# The mounted runtime provides:
# - /opt/agent-runtime/bin/uv           standalone uv binary
# - /opt/agent-runtime/bin/rg           ripgrep binary for workspace tools
# - /opt/agent-runtime/bin/python3.12   uv-managed Python 3.12 interpreter
# - /opt/agent-runtime/wheels/          offline wheelhouse for agent-teams
# - /opt/agent-runtime/bin/agent-teams  wrapper that creates a container-local venv
#
# Build:
#   docker build -f docker/Dockerfile.agent-runtime -t agent-teams-runtime:latest .
#
# Usage (data container pattern):
#   docker create --name agent-runtime agent-teams-runtime:latest
#   docker run --volumes-from agent-runtime <swebench-image> \
#       /opt/agent-runtime/bin/agent-teams server start ...

FROM python:3.12-slim-bullseye

WORKDIR /build

# -- Stage 1: dependency wheels (cached when pyproject.toml is unchanged) --
COPY pyproject.toml ./
COPY README.md ./
COPY docker/prepare_runtime_pyproject.py /build/docker/prepare_runtime_pyproject.py

RUN echo "deb http://mirrors.tuna.tsinghua.edu.cn/debian/ bullseye main" > /etc/apt/sources.list && \
    echo "deb http://mirrors.tuna.tsinghua.edu.cn/debian/ bullseye-updates main" >> /etc/apt/sources.list && \
    echo "deb http://mirrors.tuna.tsinghua.edu.cn/debian-security bullseye-security main" >> /etc/apt/sources.list && \
    apt-get update && \
    apt-get install --yes --no-install-recommends ripgrep && \
    rm -rf /var/lib/apt/lists/*

RUN python3 -m pip install --quiet --no-cache-dir \
        -i http://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple \
        --trusted-host mirrors.tuna.tsinghua.edu.cn uv

# Build a runtime-only wheel. The eval package lives in the same repository but is not needed inside the runtime image.
RUN python3 /build/docker/prepare_runtime_pyproject.py

RUN mkdir -p /opt/agent-runtime/bin /opt/agent-runtime/python /opt/agent-runtime/wheels && \
    cp /usr/local/bin/uv /opt/agent-runtime/bin/uv && \
    cp "$(command -v rg)" /opt/agent-runtime/bin/rg

RUN /opt/agent-runtime/bin/uv python install 3.12 --install-dir /opt/agent-runtime/python && \
    MANAGED_PY="$(find /opt/agent-runtime/python -path '*/bin/python3.12' -type f | head -n 1)" && \
    test -n "$MANAGED_PY" && \
    ln -s "$MANAGED_PY" /opt/agent-runtime/bin/python3.12

# Download dependency wheels only (no project source needed yet).
# This layer is cached as long as pyproject.toml does not change.
RUN python3 -m pip wheel --quiet --no-cache-dir \
        -i http://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple \
        --trusted-host mirrors.tuna.tsinghua.edu.cn \
        --wheel-dir /opt/agent-runtime/wheels \
        pydantic">=2.7.0" pydantic-ai "pydantic-ai-slim[fastmcp]" \
        PyYAML">=6.0.1" typer">=0.12.3" "fastapi>=0.100.0" \
        "uvicorn[standard]>=0.23.0" "httpx>=0.27.0"

# -- Stage 2: project wheel (rebuilds when source changes) --
COPY src/agent_teams/ src/agent_teams/
COPY frontend/dist/ /opt/agent-runtime/frontend/dist/

# Build only the project wheel; dependencies are already in the wheelhouse.
RUN python3 -m pip wheel --quiet --no-cache-dir --no-deps \
        --wheel-dir /opt/agent-runtime/wheels .

RUN printf '#!/bin/sh\n\
set -eu\n\
RUNTIME_ROOT=/opt/agent-runtime\n\
WORK_ROOT=/tmp/agent-runtime\n\
VENV_PATH=$WORK_ROOT/venv\n\
PATH="$RUNTIME_ROOT/bin:$PATH"\n\
export PATH\n\
mkdir -p "$WORK_ROOT"\n\
"$RUNTIME_ROOT/bin/uv" -q venv --clear --no-project \\\n\
    --python "$RUNTIME_ROOT/bin/python3.12" "$VENV_PATH"\n\
"$RUNTIME_ROOT/bin/uv" -q pip install --offline --no-index --no-build \\\n\
    --python "$VENV_PATH/bin/python" \\\n\
    --find-links "$RUNTIME_ROOT/wheels" agent-teams\n\
cd "$RUNTIME_ROOT"\n\
exec "$VENV_PATH/bin/agent-teams" "$@"\n' \
    > /opt/agent-runtime/bin/agent-teams && \
    chmod +x /opt/agent-runtime/bin/agent-teams && \
    mkdir -p /opt/agent-runtime/venv/bin && \
    ln -s /opt/agent-runtime/bin/agent-teams /opt/agent-runtime/venv/bin/agent-teams

# Eval entrypoint: copies host config (excluding .db) so each container
# gets its own SQLite database. Falls through to exec "$@" when no
# host config is mounted.
COPY docker/eval-entrypoint.sh /opt/agent-runtime/eval-entrypoint.sh
RUN chmod +x /opt/agent-runtime/eval-entrypoint.sh

# Smoke-test the wrapper inside the build environment.
RUN /opt/agent-runtime/bin/rg --version > /dev/null && \
    /opt/agent-runtime/bin/agent-teams --help > /dev/null

# Declare volume so --volumes-from mounts /opt/agent-runtime/ into eval containers.
VOLUME /opt/agent-runtime
